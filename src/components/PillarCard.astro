---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description } = Astro.props;
---

<div class="border-t border-slate-200 dark:border-slate-800 py-6">
  <h3 class="font-display text-lg font-semibold mb-2 text-slate-900 dark:text-slate-100">{title}</h3>
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{description}</p>
</div>
