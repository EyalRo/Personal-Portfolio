---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { data, slug } = entry;
---

<a href={`/work/${slug}/`} class="group block">
  <div class="h-full">
    {data.image && (
      <div class="mb-4 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 aspect-video">
        <img
          src={data.image}
          alt={data.title}
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    <h3 class="font-display text-lg font-semibold mb-2 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors">
      {data.title}
    </h3>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-3">{data.description}</p>
    <div class="flex flex-wrap gap-2">
      {data.tags.map((tag: string) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</a>
