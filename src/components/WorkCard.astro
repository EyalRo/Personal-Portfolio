---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { data, slug } = entry;
---

<a href={`/work/${slug}/`} class="group block">
  <div class="card h-full flex flex-col">
    {data.image && (
      <div class="mb-4 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-800 aspect-video">
        <img
          src={data.image}
          alt={data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    <div class="flex-1">
      <h3 class="heading-sm mb-2 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">
        {data.title}
      </h3>
      <p class="text-body text-sm mb-3">{data.description}</p>
      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</a>
