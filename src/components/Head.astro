---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title ? `${title} | Eyal Rotbart` : 'Eyal Rotbart';
const desc = description || 'Principal Technical Product Manager specializing in cloud infrastructure, security, and observability. 15+ years shipping enterprise products.';
const url = Astro.url.href;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={desc} />

<title>{fullTitle}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={url} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Eyal Rotbart" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={desc} />

<!-- JSON-LD Person Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Eyal Rotbart",
  "jobTitle": "Principal Technical Product Manager",
  "url": "https://isdino.com",
  "sameAs": [
    "https://www.linkedin.com/in/eyalro/",
    "https://github.com/EyalRo",
    "https://social.seattle.wa.us/@stags"
  ],
  "knowsAbout": ["Cloud Infrastructure", "Security", "Observability", "AI-Driven Operations", "Product Management"],
  "worksFor": {
    "@type": "Organization",
    "name": "Puget Sound Energy"
  }
})} />
