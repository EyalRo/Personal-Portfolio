---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Get in touch with Eyal Rotbart for opportunities, collaborations, or just to say hello.">
  <section class="container-prose py-16">
    <h1 class="heading-xl mb-4">Get in Touch</h1>
    <p class="text-body mb-12">
      I'm always open to discussing new opportunities, interesting problems, and ways to build products that matter. Whether you have a specific role in mind or just want to connect, I'd love to hear from you.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="heading-md mb-6">Direct Contact</h2>

        <div class="space-y-6">
          <a href="mailto:eyal@isdino.com" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 flex items-center justify-center flex-shrink-0 group-hover:bg-teal-100 dark:group-hover:bg-teal-900/50 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800 dark:text-slate-200">Email</span>
              <span class="text-sm text-teal-600 dark:text-teal-400 group-hover:text-teal-700 dark:group-hover:text-teal-300 transition-colors">eyal@isdino.com</span>
            </div>
          </a>

          <a href="https://www.linkedin.com/in/eyalro/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 flex items-center justify-center flex-shrink-0 group-hover:bg-teal-100 dark:group-hover:bg-teal-900/50 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800 dark:text-slate-200">LinkedIn</span>
              <span class="text-sm text-teal-600 dark:text-teal-400 group-hover:text-teal-700 dark:group-hover:text-teal-300 transition-colors">linkedin.com/in/eyalro</span>
            </div>
          </a>

          <a href="https://github.com/EyalRo" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 flex items-center justify-center flex-shrink-0 group-hover:bg-teal-100 dark:group-hover:bg-teal-900/50 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800 dark:text-slate-200">GitHub</span>
              <span class="text-sm text-teal-600 dark:text-teal-400 group-hover:text-teal-700 dark:group-hover:text-teal-300 transition-colors">github.com/EyalRo</span>
            </div>
          </a>

          <a href="https://social.seattle.wa.us/@stags" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-lg bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 flex items-center justify-center flex-shrink-0 group-hover:bg-teal-100 dark:group-hover:bg-teal-900/50 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.79 8.204.79 8.204s-.03 1.255-.03 2.459c0 1.204.15 2.459.15 2.459.03 0 .26.03.26.03l.03.03c.35 2.578 2.617 4.61 5.304 5.004.453.067 1.268.309 5.248.309h.03c3.98 0 4.835-.242 5.288-.309 2.687-.394 4.954-2.426 5.304-5.004.03-.278.03-.556.03-.834 0-1.204-.15-2.459-.15-2.459-.03 0-.26-.03-.26-.03l-.03-.03c-.35-2.578-2.617-4.61-5.304-5.004-.453-.067-1.268-.309-5.248-.309h-.03c-3.98 0-4.835.242-5.288.309-2.687.394-4.954 2.426-5.304 5.004-.03.278-.03.556-.03.834 0 1.204.15 2.459.15 2.459.03 0 .26.03.26.03l.03.03c.35 2.578 2.617 4.61 5.304 5.004.453.067 1.268.309 5.248.309h.03c3.98 0 4.835-.242 5.288-.309 2.687-.394 4.954-2.426 5.304-5.004.03-.278.03-.556.03-.834 0-1.204-.15-2.459-.15-2.459-.03 0-.26-.03-.26-.03l-.03-.03c-.35-2.578-2.617-4.61-5.304-5.004-.453-.067-1.268-.309-5.248-.309h-.03c-3.98 0-4.835.242-5.288.309-2.687.394-4.954 2.426-5.304 5.004-.03.278-.03.556-.03.834 0 1.204.15 2.459.15 2.459.03 0 .26.03.26.03l.03.03c.35 2.578 2.617 4.61 5.304 5.004.453.067 1.268.309 5.248.309h.03c3.98 0 4.835-.242 5.288-.309 2.687-.394 4.954-2.426 5.304-5.004.03-.278.03-.556.03-.834 0-1.204-.15-2.459-.15-2.459-.03 0-.26-.03-.26-.03l-.03-.03c-.35-2.578-2.617-4.61-5.304-5.004-.453-.067-1.268-.309-5.248-.309h-.03c-3.98 0-4.835.242-5.288.309-2.687.394-4.954 2.426-5.304 5.004-.03.278-.03.556-.03.834 0 1.204.15 2.459.15 2.459.03 0 .26.03.26.03l.03.03zm-8.03 8.654c-1.204 0-2.18-.976-2.18-2.18v-4.368c0-1.204.976-2.18 2.18-2.18 1.204 0 2.18.976 2.18 2.18v4.368c0 1.204-.976 2.18-2.18 2.18zm-5.304 0c-1.204 0-2.18-.976-2.18-2.18v-4.368c0-1.204.976-2.18 2.18-2.18 1.204 0 2.18.976 2.18 2.18v4.368c0 1.204-.976 2.18-2.18 2.18z"/></svg>
            </div>
            <div>
              <span class="block text-sm font-medium text-slate-800 dark:text-slate-200">Mastodon</span>
              <span class="text-sm text-teal-600 dark:text-teal-400 group-hover:text-teal-700 dark:group-hover:text-teal-300 transition-colors">social.seattle.wa.us/@stags</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Form -->
      <div>
        <h2 class="heading-md mb-6">Send a Message</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
