---
import BaseLayout from '@layouts/BaseLayout.astro';
import PillarCard from '@components/PillarCard.astro';
import WorkCard from '@components/WorkCard.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const featuredWork = allWork.filter((entry) => entry.data.featured).sort((a, b) => a.data.order - b.data.order);

const pillars = [
  {
    title: 'Systems Thinking',
    description: 'I see the whole architecture, not just my piece. Products that work at enterprise scale require understanding how systems interact, fail, and recover.',
  },
  {
    title: 'Operational Excellence',
    description: 'Effective observability requires alignment of technology, process, and culture. I shift monitoring from isolated metrics to holistic end-to-end functional health.',
  },
  {
    title: 'Security by Design',
    description: 'Security is not a checkbox. It is a product discipline. I have shipped products that passed government audits and enabled multi-billion-dollar partnerships.',
  },
  {
    title: 'Technical Translation',
    description: 'I speak engineering, executive, and customer. The best product strategy is useless if it cannot be understood and executed by every stakeholder.',
  },
];
---

<BaseLayout title="Eyal Rotbart - Principal Technical Product Manager">
  <!-- Hero -->
  <section class="relative py-20 md:py-32 overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-30 dark:opacity-20"></div>

    <div class="container-wide relative">
      <div class="flex flex-col md:flex-row items-start gap-12 md:gap-16">
        <div class="flex-1">
          <h1 class="font-display text-5xl md:text-7xl font-bold tracking-tight">
            Eyal Rotbart
          </h1>
          <span class="accent-bar bg-amber-700 dark:bg-amber-400"></span>
          <p class="font-display text-xl md:text-2xl font-medium text-slate-700 dark:text-slate-300 mb-4">
            Principal Technical Product Manager
          </p>
          <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl mb-6">
            I define and deliver enterprise products that make complex systems observable, secure, and reliable. Currently leading observability for Enterprise Integration Services at Puget Sound Energy.
          </p>
          <p class="text-sm text-slate-400 dark:text-slate-500 mb-8 flex items-center gap-3 flex-wrap">
            <span>15+ years in product</span>
            <span class="text-slate-300 dark:text-slate-700">&middot;</span>
            <span>Multi-cloud & hybrid</span>
            <span class="text-slate-300 dark:text-slate-700">&middot;</span>
            <span>Security &middot; Observability &middot; Operational Excellence</span>
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/work/" class="btn-primary">View My Work</a>
            <a href="/contact/" class="btn-secondary">Get in Touch</a>
          </div>
        </div>

        <div class="flex-shrink-0 order-first md:order-last">
          <div class="w-44 h-44 md:w-56 md:h-56 rounded-2xl overflow-hidden shadow-lg">
            <img
              src="/assets/ProfilePic.jpeg"
              alt="Eyal Rotbart"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="container-wide py-20">
    <h2 class="heading-lg mb-10">How I Work</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
      {pillars.map((pillar) => (
        <PillarCard title={pillar.title} description={pillar.description} />
      ))}
    </div>
  </section>

  <!-- Featured Work -->
  <section class="container-wide py-20">
    <div class="flex items-baseline justify-between mb-10">
      <h2 class="heading-lg">Selected Work</h2>
      <a href="/work/" class="text-sm font-medium text-amber-700 dark:text-amber-400 hover:text-amber-800 dark:hover:text-amber-300 transition-colors">
        View All &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredWork.map((entry) => (
        <WorkCard entry={entry} />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-slate-200 dark:border-slate-800">
    <div class="container-wide py-20 text-center">
      <h2 class="heading-lg mb-4">Let's talk</h2>
      <p class="text-slate-600 dark:text-slate-400 max-w-lg mx-auto mb-8 leading-relaxed">
        Open to new opportunities, interesting technical challenges, and conversations about building products that matter.
      </p>
      <a href="/contact/" class="btn-primary">Send a Message</a>
    </div>
  </section>
</BaseLayout>
